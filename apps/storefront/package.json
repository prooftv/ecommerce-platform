{
  "name": "storefront",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001 --turbopack",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:locales": "tsx scripts/check-locale-parity.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "e2e:up": "docker compose -f e2e-backend/docker-compose.yml up -d --wait && ./scripts/e2e/bootstrap-spree.sh",
    "e2e:down": "docker compose -f e2e-backend/docker-compose.yml down -v"
  },
  "dependencies": {
    "@adyen/adyen-web": "^6.33.0",
    "@next/third-parties": "^16.1.6",
    "@paypal/react-paypal-js": "^9.1.1",
    "@sanity/client": "^7.24.0",
    "@sanity/color-input": "^6.0.16",
    "@sanity/dashboard": "^6.0.12",
    "@sanity/icons": "^5.1.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/preview-url-secret": "^4.0.8",
    "@sanity/table": "^3.1.10",
    "@sanity/vision": "^6.5.0",
    "@sentry/nextjs": "^10.38.0",
    "@spree/sdk": "^1.1.0",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.7.0",
    "@swc/helpers": "^0.5.21",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "^16",
    "next-intl": "^4.9.2",
    "next-sanity": "^13.1.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "react-email": "^6.1.4",
    "react-svg-credit-card-payment-icons": "^5.1.2",
    "resend": "^6.9.4",
    "sanity": "^6.5.0",
    "sanity-plugin-dashboard-widget-document-list": "^3.0.13",
    "sanity-plugin-documents-pane": "^4.1.13",
    "sanity-plugin-media": "^6.0.4",
    "shadcn": "^4.0.2",
    "sonner": "^2.0.7",
    "styled-components": "^6.4.4",
    "swiper": "^12.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "postcss": "^8.5.10",
    "mute-stream": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@playwright/test": "^1.60.0",
    "@spree/cli": "^2.0.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.0.0",
    "lefthook": "^2.1.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
