# Spree API Configuration (server-side only)
SPREE_API_URL=https://spree-usb4.onrender.com
SPREE_PUBLISHABLE_KEY=your_publishable_api_key_here

# Stripe Configuration (client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Cloudflare R2 Storage (set on the Spree backend, not needed on the storefront)
# CLOUDFLARE_BUCKET=spree-store
# CLOUDFLARE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# CLOUDFLARE_ACCESS_KEY_ID=<access-key-id>
# CLOUDFLARE_SECRET_ACCESS_KEY=<secret-access-key>
# RAILS_STORAGE=amazon

# Sanity Content Platform
# NEXT_PUBLIC_SANITY_PROJECT_ID=52t49djs   # override to use a different project
# NEXT_PUBLIC_SANITY_DATASET=production
# SANITY_API_TOKEN=your_read_only_token         # required for Sanity Preview Mode (server-side)
# SANITY_PREVIEW_SECRET=a-long-random-string    # required for Sanity Preview Mode (server-side only, never NEXT_PUBLIC_)
