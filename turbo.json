{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "SPREE_API_URL",
        "SPREE_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_DEFAULT_COUNTRY",
        "NEXT_PUBLIC_DEFAULT_LOCALE",
        "SENTRY_DSN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_AUTH_TOKEN",
        "GTM_ID",
        "NEXT_PUBLIC_LARAVEL_API_URL",
        "NEXT_PUBLIC_SANITY_PROJECT_ID",
        "NEXT_PUBLIC_SANITY_DATASET",
        "SANITY_API_TOKEN",
        "SANITY_PROJECT_ID",
        "SANITY_PREVIEW_SECRET",
        "CLOUDFLARE_ACCESS_KEY_ID",
        "CLOUDFLARE_BUCKET",
        "CLOUDFLARE_ENDPOINT",
        "CLOUDFLARE_SECRET_ACCESS_KEY",
        "RAILS_STORAGE",
        "AWS_REGION",
        "LARAVEL_API_URL",
        "LARAVEL_API_SECRET"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:e2e": {
      "cache": false
    }
  }
}
